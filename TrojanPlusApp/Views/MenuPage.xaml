<?xml version="1.0" encoding="utf-8" ?>
 <ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:TrojanPlusApp.Models"
             mc:Ignorable="d"
             x:Class="TrojanPlusApp.Views.MenuPage"
             Title="Menu">

	<StackLayout VerticalOptions="FillAndExpand">
		<CollectionView x:Name="CollectionViewMenu" SelectionMode="None">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="models:HomeMenuItem">
					<Grid Padding="10">
						<Label Text="{Binding Title}" FontSize="20" TextColor="Gray"/>
						<Grid.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnMenuTapped" />
						</Grid.GestureRecognizers>
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</StackLayout>

</ContentPage>